# SafePickup environment template.
# Copy this file to `.env.local` for local development. Production deploys
# inject these via the platform (Vercel env, Docker secrets, etc.).
#
# Variables WITHOUT the `NEXT_PUBLIC_` prefix are server-only — they never
# ship in the client bundle.

# ─────────────────────────────────────────────────────────────────────────
# Upstream backend
# ─────────────────────────────────────────────────────────────────────────
# Real backend the server-side handlers proxy to when not in mock mode.
# Leave empty to force mock-only behaviour.
BACKEND_API_URL=https://api-dev.studentpickup.app

# Axios timeout (ms) for upstream calls.
BACKEND_API_TIMEOUT_MS=15000

# Optional bearer token forwarded as `Authorization: Bearer <token>`.
# BACKEND_API_TOKEN=

# ─────────────────────────────────────────────────────────────────────────
# Mock vs real routing
# ─────────────────────────────────────────────────────────────────────────
# Global default. `mock` keeps everything on the in-memory `mockDB`; `real`
# proxies every domain to BACKEND_API_URL.
API_MODE=mock

# Comma-separated domain keys (matching the keys passed to `mockable({ domain })`)
# that should ALWAYS use mock data, even when API_MODE=real. Useful while a
# specific endpoint is still under construction on the backend.
# Example: API_MOCK_DOMAINS=schools,gates,beacons
API_MOCK_DOMAINS=

# Comma-separated domain keys that should use the real backend even when
# API_MODE=mock. Use this to flip ONE domain to live while everything else
# stays on mocks. Takes precedence over API_MOCK_DOMAINS.
# Example: API_REAL_DOMAINS=students,staff
API_REAL_DOMAINS=

# ─────────────────────────────────────────────────────────────────────────
# Public (client-readable) values
# ─────────────────────────────────────────────────────────────────────────
# These ARE shipped in the client bundle. Don't put secrets here.
NEXT_PUBLIC_APP_NAME=SafePickup

# OAuth client_id sent to /api/v1/auth/login.
#
# Normally NOT needed — the login page picks the right client_id per portal
# automatically (`resolveClientId()` in src/lib/auth/client-id.ts):
#   /admin    → admin_crm
#   /staff    → stuff_crm     (sic — backend's literal value)
#   /business → business_crm
#   /tv       → dashboard_crm
#
# Set this to override (e.g. force `parent_mobile_app` while debugging).
# NEXT_PUBLIC_AUTH_CLIENT_ID=

# Display-only fallback for the school name shown in the portal header.
# TEMP: backend hasn't shipped `GET /api/v1/schools/:id` yet — until then
# the PortalShell skips the network request and renders this string.
# Remove once the backend endpoint is live and PortalShell is flipped back
# to `useApi(apiKeys.schools.byId(...))`.
NEXT_PUBLIC_MOCK_SCHOOL_NAME=Bangkok International School
